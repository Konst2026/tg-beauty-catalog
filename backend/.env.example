# Telegram — токен основного бота (для верификации initData)
BOT_TOKEN=replace_with_main_bot_token

# Сервер
PORT=3000
HOST=0.0.0.0

# CORS — список доменов через запятую (пусто = разрешить все, только для dev)
# Пример: https://app.beautybook.com,https://staging.beautybook.com
ALLOWED_ORIGINS=

# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Database (Transaction pooler — для всех запросов из Node.js)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Database (Direct connection — только для миграций)
DATABASE_DIRECT_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres

# Шифрование bot_token (сгенерируй: openssl rand -hex 32)
MASTER_SECRET_KEY=

# Redis
REDIS_URL=redis://localhost:6379

# Платформа
PLATFORM_URL=https://api.beautybook.com
MINI_APP_URL=https://app.beautybook.com

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Stripe (Кипр/ЕС)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
